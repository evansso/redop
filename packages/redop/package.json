{
  "name": "@redopjs/redop",
  "version": "0.1.6",
  "description": "Bun-native MCP server framework",
  "keywords": [
    "bun",
    "framework",
    "mcp",
    "model-context-protocol",
    "typescript"
  ],
  "homepage": "https://redop.useagents.site",
  "repository": {
    "type": "git",
    "url": "https://github.com/redopjs/redop.git"
  },
  "bugs": {
    "url": "https://github.com/redopjs/redop/issues"
  },
  "author": {
    "name": "Evans Maina",
    "url": "https://github.com/evansso"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && bun run ./scripts/build.ts && tsc -p tsconfig.build.json",
    "build:js": "bun run clean && bun run ./scripts/build.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
