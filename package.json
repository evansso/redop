{
  "name": "redopjs",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "dev:web": "turbo run dev --filter=@redopjs/web",
    "build:web": "turbo run build --filter=@redopjs/web",
    "start:web": "turbo run start --filter=@redopjs/web"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "turbo": "^2.8.19",
    "typescript": "5.9.2",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
